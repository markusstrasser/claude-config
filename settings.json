{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeGitInstructions": false,
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/permission-auto-allow.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-bash-loop-guard.sh"
          },
          {
            "type": "command",
            "command": "cmd=$(echo \"$CLAUDE_TOOL_INPUT\" | grep -oE '\"command\":\\s*\"[^\"]*\"' | head -1); if echo \"$cmd\" | grep -qE '\"(python |python3 )' && ! echo \"$cmd\" | grep -q 'uv run'; then echo 'BLOCK: use \"uv run python\" not bare python'; exit 2; fi"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-llmx-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/pretool-modal-cost-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-cost-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-ast-precommit.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-commit-check.sh"
          }
        ]
      },
      {
        "matcher": "mcp__exa|mcp__research|mcp__paper-search|mcp__brave-search|mcp__perplexity|mcp__firecrawl|mcp__scite|WebSearch|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-search-burst.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-consensus-search.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/tool-tracker.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-companion-remind.sh"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-subagent-gate.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/pretool-shared-infra-guard.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-source-remind.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-regression-dag-gate.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/pretool-goal-drift.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "INPUT=$(cat); FPATH=$(echo \"$INPUT\" | grep -oE '\"file_path\"\\s*:\\s*\"[^\"]*MEMORY\\.md\"' | head -1); if [ -n \"$FPATH\" ]; then FILE=$(echo \"$FPATH\" | sed 's/.*\"file_path\"\\s*:\\s*\"//;s/\"//'); if [ -f \"$FILE\" ]; then LINES=$(wc -l < \"$FILE\"); if [ \"$LINES\" -gt 180 ]; then echo \"WARNING: MEMORY.md is $LINES lines (limit 200, truncated at load). Move detailed content to topic files and keep MEMORY.md as a concise index.\" >&2; fi; fi; fi"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/postwrite-source-check.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/alien/Projects/meta/scripts/hooks/null-result-advisory.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-verify-before-expand.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/postwrite-frontier-timeliness.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/substrate-registration-reminder.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-bash-failure-loop.sh",
            "statusMessage": "Checking for failure loops..."
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-review-check.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-verify-before-expand.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/postcommit-propagate-check.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/spinning-detector.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-l3-telemetry.sh"
          }
        ]
      },
      {
        "matcher": "mcp__research__read_paper|mcp__research__fetch_paper|mcp__research__search_papers|mcp__exa__web_search_exa|mcp__exa__web_search_advanced_exa|mcp__exa__crawling_exa|mcp__brave-search__brave_web_search|mcp__brave-search__brave_news_search|mcp__paper-search__search_arxiv|mcp__paper-search__search_pubmed|mcp__paper-search__search_biorxiv|mcp__paper-search__search_medrxiv|mcp__paper-search__search_google_scholar|mcp__firecrawl__firecrawl_scrape|mcp__firecrawl__firecrawl_extract|mcp__scite__search_literature",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-research-reformat.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/stop-plan-status.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/stop-verify-plan.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/stop-uncommitted-warn.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/stop-debrief.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/stop-notify.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/precompact-log.sh",
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/postcompact-verify.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/userprompt-context-warn.sh"
          },
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/tab-color.sh working"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/.claude/hooks/session-init.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/subagent-start-log.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/subagent-epistemic-gate.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/posttool-failure-log.sh",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/sessionend-log.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/sessionend-overview-trigger.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/sessionend-index-sessions.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
